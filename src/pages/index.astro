---
// Root redirect page - detects browser language and redirects
---
<!DOCTYPE html>
<html>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>BeaversLab</title>
    <script is:inline>
      (function() {
        // Get browser language
        const browserLang = navigator.language || navigator.userLanguage;
        const lang = browserLang.toLowerCase().startsWith('zh') ? 'zh' : 'en';
        
        // Check if user has a saved preference
        const savedLang = localStorage.getItem('preferred-language');
        const targetLang = savedLang || lang;
        
        // Redirect to appropriate language path
        window.location.replace('/' + targetLang + '/');
      })();
    </script>
  </head>
  <body style="margin:0;background:#03111b;color:#effdff;font-family:sans-serif;display:flex;align-items:center;justify-content:center;height:100vh;">
    <p id="loading-text">Loading...</p>
    <script is:inline>
      // Show localized loading text
      (function() {
        const browserLang = navigator.language || navigator.userLanguage;
        const isZh = browserLang.toLowerCase().startsWith('zh');
        document.getElementById('loading-text').textContent = isZh ? '加载中...' : 'Loading...';
      })();
    </script>
  </body>
</html>
