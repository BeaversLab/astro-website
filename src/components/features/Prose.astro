---
import type { Lang } from '@/utils/i18n';

interface Props {
  lang?: Lang;
}

const { lang } = Astro.props as Props;
const resolvedLang = ((Astro.currentLocale as string | undefined) ??
  (lang as string | undefined) ??
  'en') as Lang;
const isCJK = ['zh', 'ja', 'ko'].includes(resolvedLang);
const containerClass = [
  'prose max-w-none md:max-w-3xl lg:max-w-4xl xl:max-w-5xl mx-auto',
  isCJK ? 'prose-p:text-justify prose-li:text-justify' : 'prose-p:text-left prose-li:text-left',
].join(' ');
---

<div class="prose-panel mx-auto max-w-5xl">
  <div class={containerClass}>
    <slot />
  </div>
</div>

<style>
  .prose-panel {
    background: var(--panel-strong);
    backdrop-filter: blur(20px);
    -webkit-backdrop-filter: blur(20px);
    border: 1px solid var(--line);
    border-radius: 1rem;
    padding: 2rem 1.5rem;
  }

  @media (min-width: 640px) {
    .prose-panel {
      padding: 2.5rem 2rem;
    }
  }

  @media (min-width: 768px) {
    .prose-panel {
      padding: 3rem 2.5rem;
    }
  }
</style>
